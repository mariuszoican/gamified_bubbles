## 0. CORE PRINCIPLE — ONE CONFIG FILE, STABLE SCRIPTS
# The three analysis scripts are PERMANENT. They never change when
# new data arrives. The ONLY file that changes is config.py.
# When a new session is collected:
#   1. Add session code to SESSION_CODES in config.py
#   2. Update DATE in config.py if a new export was made
#   3. Re-run the three scripts — unchanged


## 1. config.py — THE ONLY FILE THAT EVER CHANGES
# Lives in code/ alongside the scripts. Structure:
#
# DATE = "2026-03-27"
# SESSION_CODES = [
#     "tmjewif2",        # Session 1 — 2026-03-27
#     # "abc12345",      # Session 2 — not yet collected
# ]
# COMPLETION_PAGE    = "FinalForProlific"
# N_PERIODS          = 15
# N_MARKETS          = 2
# N_TRADERS          = 8
# DIV_VALUES         = [0, 4, 8, 20]
# EXP_DIV            = 8
# BASELINE_TREATMENT = "nh"
# DATA_DIR           = "../data"
# OUTPUT_DIR         = "../generated_data"
# RENAME = {
#     "participant.code":                       "participant_code",
#     "participant.payoff":                     "payoff_total",
#     "player.id_in_group":                     "trader_id",
#     "player.trader_uuid":                     "trader_uuid",
#     "player.current_cash":                    "cash_end",
#     "player.num_shares":                      "shares_end",
#     "player.forecast_price_next_day":         "forecast_price",
#     "player.forecast_confidence_next_day":    "forecast_confidence",
#     "player.realized_next_day_closing_price": "realized_price",
#     "player.forecast_bonus_scored":           "forecast_hit",
#     "player.num_correct_answers":             "fin_lit_score",
#     "player.self_assesment":                  "self_assess",
#     "group.market_design":                    "market_design",
#     "group.group_composition":                "group_composition",
#     "group.treatment":                        "treatment",
#     "group.trading_session_uuid":             "session_uuid",
#     "group.closing_price":                    "closing_price",
#     "group.noise_trader_present":             "algo_present",
#     "subsession.round_number":                "market_rep",
# }
#
# Every script begins with:  from config import *
# File paths:  f"{DATA_DIR}/trader_bridge_app_{DATE}.csv"


## 2. FILE & FOLDER STRUCTURE
# code/
#   config.py               <- ONLY file updated between sessions
#   prepare_panels.py       <- Step 1: permanent
#   compute_variables.py    <- Step 2: permanent
#   hypothesis_tests.py     <- Step 3: permanent
# data/                     <- READ-ONLY raw oTree exports
# generated_data/           <- scripts write here (stable filenames)
# figures/                  <- out of scope for current phase


